            <pipeline
              version="1">
              <components>
                <component
                  refId="Package\Eltiam\DimCustomer\Eltiam"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="Eltiam"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">--drop table if exists dw..dimcustomer

--alter table dw..dimcustomer
--add id [bigint] identity (1,1) not null 


--truncate table dw..dimcustomer



SELECT  CU.Id as CustomerKey,
              CU.Code AS CustomerCode,
			  isnull (c.FINDetailAccountKey, cu.Code) accountid,
              CU.Name AS Customer,
			  cu.IsDeactivated status,


              --IsDeactivated  ,
              CU.CenterKey as CenterKeyNow,
              C.CenterName AS CenterNow,
              --cd.CityKey,  
			  
              CT.Id AS CustomerTypeKey,
              CT.Name AS CustomerType,

              PT.Name AS PharmacyType,
              CAST(CD.IsPrivatelyOwned AS int) AS OwnershipTypeKey,

              cast ((CASE CD.IsPrivatelyOwned WHEN 1 THEN N'خصوصی' ELSE N'دولتی' END) as nvarchar(10)) AS OwnershipType,

              CAST(CD.PaymentBehavior AS int) AS PaymentBehaviorKey,
              cast ((CASE CD.PaymentBehavior WHEN 1 THEN N'خصوصی' ELSE N'دولتی' END)as nvarchar(10))  AS  PaymentBehavior,
              --cd.CustomerRegulatoryAgencyKey AS RegulatoryAgencyKey,
			  cast (case when  cd.IsHospital =1 then N'بیمارستان' else N'سایر' end as nvarchar(10))   as kind,


              RA.[Name] AS RegulatoryAgency,
              CA.[Address] AS CustomerAddressNow,

              cd.DefaultSalesman as DefaultSalesmanKey,
              s.Name as DefaultSalesman,        

              R.SalesRouteKey as SalesRouteKeyNow, 
              R.SalesRoute	  as SalesRouteNow,

              case when CU.Status =1 then N'فعال'  else N'غیرفعال' end AS CustomerStatus,
              D.DateKey AS CreatedDateKey,
			  cast (cu.Latitude as float)Latitude,
			  cast (cu.Longitude as float)Longitude ,
			  cd.GLN,

			  1 as company

--into dw..dimcustomer
			  
FROM eltiam.PUBCustomers CU
LEFT JOIN (select * from eltiam.PUBCustomerDetails) CD
       ON CU.Id = CD.Id
LEFT JOIN (select * from eltiam.PUBCustomerTypes) CT
       ON CT.Id = CD.CustomerTypeKey
LEFT JOIN (select * from eltiam.PUBPharmacyTypes) PT
       ON PT.Id = CD.PharmacyTypKey
LEFT JOIN
(
       SELECT *
              FROM
              (
              SELECT ROW_NUMBER() OVER (PARTITION BY CustomerKey ORDER BY IsDefault DESC, Modified DESC) AS Row_No, CustomerKey, [Address], IsDefault--, POBoxCode
              FROM eltiam.PUBCustomerAddresses
              --WHERE IsDefault = 1
              ) T
       WHERE Row_No = 1
) CA
       ON CD.Id = CA.CustomerKey
LEFT JOIN
(
       SELECT PR.CustomerKey, pr.SalesRouteKey , SR.Name AS SalesRoute
       FROM eltiam.SLSSalesRoutes SR
       LEFT JOIN eltiam.PUBCustomerSalesRoutes PR
              ON SR.Id = PR.SalesRouteKey
       WHERE PR.EndDateKey = 99999999
) R
       ON CU.Id = R.CustomerKey
LEFT JOIN eltiam.PUBCenters C
       ON C.Id = CU.CenterKey
LEFT JOIN eltiam.SLSSalesmans S
       ON S.Id = CD.DefaultSalesman
LEFT JOIN (select id,Name from eltiam.PUBCustomerRegulatoryAgency) RA
       ON RA.Id = CD.CustomerRegulatoryAgencyKey
LEFT JOIN (select DateKey,date from dimdate) D
       ON D.date = CAST(CD.Created AS date)

	   --where cd.PaymentBehavior is null</property>
