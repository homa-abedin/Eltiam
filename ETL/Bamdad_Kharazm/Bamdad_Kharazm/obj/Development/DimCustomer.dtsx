      DTS:ObjectName="KHarazmi">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\KHarazmi\DimCustomer"
          DTS:CreationName="Microsoft.Pipeline"
          DTS:Description="Data Flow Task"
          DTS:DTSID="{d1928075-afd9-4282-b21c-bbfd5e3a2940}"
          DTS:ExecutableType="Microsoft.Pipeline"
          DTS:LocaleID="-1"
          DTS:ObjectName="DimCustomer"
          DTS:TaskContact="Performs high-performance data extraction, transformation and loading;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
          <DTS:Variables />
          <DTS:ObjectData>
            <pipeline
              version="1">
              <components>
                <component
                  refId="Package\KHarazmi\DimCustomer\kharazmi"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="kharazmi"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">--drop table if exists  [DW_kharazmi]..dimcustomer



 select 
c.CustomerID  CustomerKey
,c.Number CustomerCode
,ISNULL(d.DLID,c.number)accountid
, p.FullName  AS  customer
--,p.firstname
--,p.lastname
,c.State as status
, -1 as CenterKeyNow
, null AS CenterNow
--,p.partyid
,20 AS CustomerTypeKey
,N'پخش' AS CustomerType

,NULL AS PharmacyType
,NULL   AS OwnershipTypeKey
,null AS OwnershipType
,NULL as PaymentBehaviorKey
,NULL AS PaymentBehavior
,NULL as kind
, NULL AS RegulatoryAgency
 
,cast (a.Details as  nvarchar (1024)) as CustomerAddressNow
,NULL  as DefaultSalesmanKey
,null  as DefaultSalesman

,NULL as SalesRouteKeyNow
,null as SalesRouteNow
,case when C.State =1 then N'فعال'  else N'غیرفعال' end AS CustomerStatus

,dd.datekey AS CreatedDateKey
,a.Latitude
,a.Longitude
, null 	as GLN
, 2 as company


--,a.RegionalDivisionRef

--,d.Title as TitleDl
--,d.Code as CodeDL,ac.AccountID,ac.Name NameAccount,ac.Number NumberAccount
--,EntityGroupingID,  groupingname,  groupid, namegroup,  subgroupid,  namesubgroup 
--,changedate,dd.idpersian createpersian,r.*

 --into [DW_kharazmi]..dimcustomer 
--select * 
 from 
 kharazmi.customer c
 left join (Select * from kharazmi.Party) p on p.PartyID=c.PartyRef
 left join (Select * from  kharazmi.CustomerAddress 
 where Type=1 and IsActive=1  and isdefault=1 AND State = 1
 ) ca on ca.CustomerRef=c.CustomerID
 left join (Select * from kharazmi.Address  ) a on a.AddressID=ca.AddressRef
 --left join (
	--		select 
	--		--egi.EntityGroupingID, egi.name groupingname,
	--		eg1.EntityGroupID groupid,EG1.Name namegroup, eg.EntityGroupID subgroupid, EG.Name namesubgroup--, gm.memberid  
	--		from  kharazmi.EntityGroup EG 
	--		join (select * from kharazmi.EntityGroup)EG1 on EG1.EntityGroupID=isnull(EG.ParentRef,EG.EntityGroupID)
	--		join (select * from kharazmi.EntityGrouping) egi on egi.EntityGroupingID=EG1.EntityGroupingRef
	--		--join (select * from kharazmi.[CustomerGroupMembers])gm on gm.GroupRef=eg.EntityGroupID 
	--		--where  entityname like 'customer'
	--		)category on category.MemberID=c.CustomerID
left join (select * from kharazmi.dl where DLTypeRef=1 )d on d.ReferenceID=p.partyid
left join (select * from dimdate) dd on dd.Date= c.CreationDate
--left join (select top(1)AccountID,name,Number,PartyRef from kharazmi.Account)ac on ac.PartyRef=p.PartyID</property>
