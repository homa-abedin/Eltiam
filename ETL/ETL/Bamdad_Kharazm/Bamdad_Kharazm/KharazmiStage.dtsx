          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Delete T"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{77B1D012-A2BC-4B83-A26F-ADCFCAA2F12B}"
              SQLTask:SqlStatementSource="  delete ft &#xA;  from eltiam.ARPReceivables ft&#xA; inner join (select * from [Stage].[dbo].updates) tft1 on tft1.[id]=ft.ID" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
