          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{77B1D012-A2BC-4B83-A26F-ADCFCAA2F12B}"
              SQLTask:SqlStatementSource=" insert into eltiam.ARPReceivables &#xA;(&#xA;[Id]&#xA;      ,[PUBFiscalYearKey]&#xA;      ,[CenterKey]&#xA;      ,[CustomerKey]&#xA;      ,[ARPersonnelKey]&#xA;      ,[PaymentMethodLookup]&#xA;      ,[DateKey]&#xA;      ,[ChequeDateKey]&#xA;      ,[Amount]&#xA;      ,[Number]&#xA;      ,[LastStatusLookup]&#xA;      ,[Dsc]&#xA;      ,[CreatedBy]&#xA;      ,[Created]&#xA;      ,[ModifiedBy]&#xA;      ,[Modified]&#xA;      ,[RowVersion]&#xA;      ,[CustomerBankAccountKey]&#xA;      ,[AppliedAmount]&#xA;      ,[IsOverPayApr]&#xA;      ,[BankAccountKey]&#xA;      ,[RemainAmountIfBounced]&#xA;      ,[ConvertedId]&#xA;      ,[IsPostedToDT]&#xA;      ,[IsNewType]&#xA;      ,[isupdate]&#xA;      ,[isinsert]&#xA;   )                  &#xA;   select&#xA;[Id]&#xA;      ,[PUBFiscalYearKey]&#xA;      ,[CenterKey]&#xA;      ,[CustomerKey]&#xA;      ,[ARPersonnelKey]&#xA;      ,[PaymentMethodLookup]&#xA;      ,[DateKey]&#xA;      ,[ChequeDateKey]&#xA;      ,[Amount]&#xA;      ,[Number]&#xA;      ,[LastStatusLookup]&#xA;      ,[Dsc]&#xA;      ,[CreatedBy]&#xA;      ,[Created]&#xA;      ,[ModifiedBy]&#xA;      ,[Modified]&#xA;      ,[RowVersion]&#xA;      ,[CustomerBankAccountKey]&#xA;      ,[AppliedAmount]&#xA;      ,[IsOverPayApr]&#xA;      ,[BankAccountKey]&#xA;      ,[RemainAmountIfBounced]&#xA;      ,[ConvertedId]&#xA;      ,[IsPostedToDT]&#xA;      ,[IsNewType]&#xA;&#xA;   ,null&#xA;   ,1&#xA;   FROM [192.168.10.5].[Eltiam].[dbo].ARPReceivables QuotasDetails&#xA;where&#xA;--QuotasDetails.created&gt;=cast (cast( year(getdate()) as varchar )+'-01-01' as date) and &#xA;not exists(&#xA; select id from eltiam.ARPReceivables z1 where z1.[id] = QuotasDetails.[Id])" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
