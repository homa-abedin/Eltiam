              SQLTask:SqlStatementSource="delete from [eltiam].[ARPReceivables] &#xA;where not exists (select * from [192.168.10.5].[Eltiam].[dbo].[ARPReceivables] f where f.ID=eltiam.ARPReceivables.ID)&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
