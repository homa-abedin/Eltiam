          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{77B1D012-A2BC-4B83-A26F-ADCFCAA2F12B}"
              SQLTask:SqlStatementSource=" insert into eltiam.ARPReceivables &#xA;(&#xA;[Id]&#xA;      ,[PUBFiscalYearKey]&#xA;      ,[CenterKey]&#xA;      ,[CustomerKey]&#xA;      ,[ARPersonnelKey]&#xA;      ,[PaymentMethodLookup]&#xA;      ,[DateKey]&#xA;      ,[ChequeDateKey]&#xA;      ,[Amount]&#xA;      ,[Number]&#xA;      ,[LastStatusLookup]&#xA;      ,[Dsc]&#xA;      ,[CreatedBy]&#xA;      ,[Created]&#xA;      ,[ModifiedBy]&#xA;      ,[Modified]&#xA;      ,[RowVersion]&#xA;      ,[CustomerBankAccountKey]&#xA;      ,[AppliedAmount]&#xA;      ,[IsOverPayApr]&#xA;      ,[BankAccountKey]&#xA;      ,[RemainAmountIfBounced]&#xA;      ,[ConvertedId]&#xA;      ,[IsPostedToDT]&#xA;      ,[IsNewType]&#xA;      ,[isupdate]&#xA;      ,[isinsert]&#xA;   )                  &#xA;   select&#xA;[Id]&#xA;      ,[PUBFiscalYearKey]&#xA;      ,[CenterKey]&#xA;      ,[CustomerKey]&#xA;      ,[ARPersonnelKey]&#xA;      ,[PaymentMethodLookup]&#xA;      ,[DateKey]&#xA;      ,[ChequeDateKey]&#xA;      ,[Amount]&#xA;      ,[Number]&#xA;      ,[LastStatusLookup]&#xA;      ,[Dsc]&#xA;      ,[CreatedBy]&#xA;      ,[Created]&#xA;      ,[ModifiedBy]&#xA;      ,[Modified]&#xA;      ,[RowVersion]&#xA;      ,[CustomerBankAccountKey]&#xA;      ,[AppliedAmount]&#xA;      ,[IsOverPayApr]&#xA;      ,[BankAccountKey]&#xA;      ,[RemainAmountIfBounced]&#xA;      ,[ConvertedId]&#xA;      ,[IsPostedToDT]&#xA;      ,[IsNewType]&#xA;&#xA;   ,1&#xA;   ,NULL&#xA;   FROM [192.168.10.5].[Eltiam].[dbo].ARPReceivables QuotasDetails&#xA;where&#xA;--QuotasDetails.created&gt;=cast (cast( year(getdate()) as varchar )+'-01-01' as date) and &#xA;not exists(&#xA; select id from eltiam.ARPReceivables z1 where z1.[id] = QuotasDetails.[Id])&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\InvoiceItem\update"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{eab8f8f9-c412-476b-ad64-1c6b712744fd}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="update"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{77B1D012-A2BC-4B83-A26F-ADCFCAA2F12B}"
              SQLTask:SqlStatementSource=" truncate table [Stage].[dbo].[Updates]&#xA; insert into [stage].[dbo].[updates]&#xA; (id)&#xA; select sc.id&#xA; from  eltiam.ARPReceivables c&#xA;&#xA; inner join  (select * from [192.168.10.5].[Eltiam].[dbo].[ARPReceivables])  sc  on  sc.created&gt;=cast (cast( year(getdate()) as varchar )+'-01-01' as date) and&#xA; sc.ID=c.ID and sc.RowVersion&lt;&gt; c.RowVersion&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
